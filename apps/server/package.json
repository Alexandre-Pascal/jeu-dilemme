{
  "name": "@dilemme/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0 || true",
    "test": "vitest run"
  },
  "dependencies": {
    "@dilemme/shared": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@prisma/client": "^6.3.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
