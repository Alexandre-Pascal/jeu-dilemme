# Base PostgreSQL (local: docker compose ; prod: Neon)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dilemme"

# Serveur API + Socket.io
PORT=3001
HOST=0.0.0.0

# Origine du front Vite (dev) ou Cloudflare Pages (prod)
CORS_ORIGIN="http://localhost:5173"

# Optionnel (tests locaux) : n’utiliser que les N premières offres en base (ex. 2 pour une partie courte).
# TEST_OFFER_LIMIT=2
